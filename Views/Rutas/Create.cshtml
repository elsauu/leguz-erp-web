@model LEGUZ.Models.Entities.DeliveryRoute
@{
    ViewData["Title"] = "Nueva Ruta";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-map me-2 text-primary"></i>Nueva ruta
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Número</label>
                        <input asp-for="Number" class="form-control" type="number" min="1" max="99" />
                        <span asp-validation-for="Number" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Nombre</label>
                        <input asp-for="Name" class="form-control" placeholder="Ej. BALCONES RIOS" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar
                        </button>
                        <a href="/Rutas" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>