@model DailyRouteRecord
@{
    var ruta = (DeliveryRoute)ViewBag.Ruta;
    var fecha = (DateOnly)ViewBag.Fecha;
    bool isEdit = Model.DailyRouteRecordId > 0;
    string formAction = isEdit
        ? $"/Cuadranza/Editar/{Model.DailyRouteRecordId}"
        : "/Cuadranza/Capturar";
    var cultura = new System.Globalization.CultureInfo("es-MX");
}

<div class="mb-3">
    <a href="/Cuadranza?fecha=@fecha.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver al día
    </a>
</div>

<!-- Banner de información -->
<div class="card mb-4" style="background:linear-gradient(135deg,#1e3a5f,#0f2744);border:none;">
    <div class="card-body d-flex align-items-center gap-4 py-3 flex-wrap">
        <div>
            <div style="color:rgba(255,255,255,.45);font-size:.68rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;">Ruta</div>
            <div style="color:#fff;font-size:1.15rem;font-weight:700;">
                @ruta.Number.ToString("D2") — @ruta.Name
            </div>
        </div>
        <div style="width:1px;background:rgba(255,255,255,.15);height:36px;"></div>
        <div>
            <div style="color:rgba(255,255,255,.45);font-size:.68rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;">Fecha</div>
            <div style="color:#fff;font-size:.95rem;font-weight:500;">
                @fecha.ToString("dddd dd 'de' MMMM yyyy", cultura)
            </div>
        </div>
        @if (isEdit)
        {
            <div style="width:1px;background:rgba(255,255,255,.15);height:36px;"></div>
            <div>
                <span style="background:rgba(245,158,11,.25);color:#fbbf24;padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:600;">
                    <i class="bi bi-pencil me-1"></i>Editando registro
                </span>
            </div>
        }
    </div>
</div>

<form method="post" action="@formAction">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="DailyRouteRecordId" />
    <input type="hidden" asp-for="Date" />
    <input type="hidden" asp-for="DeliveryRouteId" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="CreatedBy" />

    <div class="row g-4">

        <!-- Columna izquierda: secciones de captura -->
        <div class="col-lg-8">

            <!-- CARGA -->
            <div class="card mb-4">
                <div class="card-header" style="background:#eff6ff;color:#1e40af;">
                    <i class="bi bi-box-arrow-up-right me-2"></i>CARGA — Salida del almacén
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Cantidades que salieron con el vendedor.</p>

                    <div class="row g-3">
                        <div class="col-4">
                            <label class="form-label small fw-semibold">Kilos caliente</label>
                            <input asp-for="LoadHotKilos" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold">½ Kilos</label>
                            <input asp-for="LoadHalfKilo" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold">Kilo Taco</label>
                            <input asp-for="LoadTacoKilo" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold">Paquetes</label>
                            <input asp-for="LoadPackages" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold">½ Paquetes</label>
                            <input asp-for="LoadHalfPackage" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold">Paq. Taco</label>
                            <input asp-for="LoadTacoPackage" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-3">
                            <label class="form-label small fw-semibold">Totopos</label>
                            <input asp-for="LoadChips" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-3">
                            <label class="form-label small fw-semibold">Masa</label>
                            <input asp-for="LoadDough" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-3">
                            <label class="form-label small fw-semibold">Chicharrones</label>
                            <input asp-for="LoadCrackling" type="number" step="1" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-3">
                            <label class="form-label small fw-semibold">Presentación</label>
                            <input asp-for="LoadPresentation" type="number" step="1" min="0"
                                   class="form-control" />
                        </div>
                    </div>

                    <!-- Totales de carga -->
                    <div class="mt-3 pt-3" style="border-top:1px solid #e5e7eb;">
                        <div class="row g-2">
                            <div class="col-6">
                                <div style="background:#dbeafe;border-radius:8px;padding:8px 12px;">
                                    <div style="font-size:.68rem;font-weight:600;color:#1e40af;text-transform:uppercase;letter-spacing:.5px;">Total Caliente</div>
                                    <div class="fw-bold" id="totalCaliente" style="color:#1d4ed8;">—</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div style="background:#dcfce7;border-radius:8px;padding:8px 12px;">
                                    <div style="font-size:.68rem;font-weight:600;color:#166534;text-transform:uppercase;letter-spacing:.5px;">Total Frío</div>
                                    <div class="fw-bold" id="totalFrio" style="color:#15803d;">—</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TABLA -->
            <div class="card mb-4">
                <div class="card-header" style="background:#f0fdf4;color:#166534;">
                    <i class="bi bi-table me-2"></i>TABLA — Registro de producción
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Lo que debería haber vendido según producción.</p>
                    <div class="row g-3">
                        <div class="col-4">
                            <label class="form-label small fw-semibold">Kilos</label>
                            <input asp-for="TableHotKilos" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold">Paquetes</label>
                            <input asp-for="TablePackages" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-semibold">Totopos</label>
                            <input asp-for="TableChips" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Masa</label>
                            <input asp-for="TableDough" type="number" step="0.01" min="0"
                                   class="form-control calc-input" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Chicharrones</label>
                            <input asp-for="TableCrackling" type="number" step="1" min="0"
                                   class="form-control calc-input" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- VENTAS Y DEVOLUCIONES -->
            <div class="card mb-4">
                <div class="card-header" style="background:#fff7ed;color:#9a3412;">
                    <i class="bi bi-arrow-left-right me-2"></i>VENTAS Y DEVOLUCIONES
                </div>
                <div class="card-body">
                    <!-- Header de columnas -->
                    <div class="row g-2 mb-1">
                        <div class="col-4"></div>
                        <div class="col-4 text-center">
                            <span style="font-size:.7rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Venta</span>
                        </div>
                        <div class="col-4 text-center">
                            <span style="font-size:.7rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Devolución</span>
                        </div>
                    </div>

                    <!-- Kilos -->
                    <div class="row g-2 mb-2 align-items-center">
                        <div class="col-4"><span class="small fw-semibold">Kilos caliente</span></div>
                        <div class="col-4">
                            <input asp-for="KilosSold" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                        <div class="col-4">
                            <input asp-for="KilosReturned" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                    </div>

                    <!-- Paquetes -->
                    <div class="row g-2 mb-2 align-items-center">
                        <div class="col-4"><span class="small fw-semibold">Paquetes</span></div>
                        <div class="col-4">
                            <input asp-for="PackagesSold" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                        <div class="col-4">
                            <input asp-for="PackagesReturned" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                    </div>

                    <!-- Totopos -->
                    <div class="row g-2 mb-2 align-items-center">
                        <div class="col-4"><span class="small fw-semibold">Totopos</span></div>
                        <div class="col-4">
                            <input asp-for="ChipsSold" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                        <div class="col-4">
                            <input asp-for="ChipsReturned" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                    </div>

                    <!-- Masa -->
                    <div class="row g-2 mb-2 align-items-center">
                        <div class="col-4"><span class="small fw-semibold">Masa</span></div>
                        <div class="col-4">
                            <input asp-for="DoughSold" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                        <div class="col-4">
                            <input asp-for="DoughReturned" type="number" step="0.01" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                    </div>

                    <!-- Chicharrones (solo venta) -->
                    <div class="row g-2 align-items-center">
                        <div class="col-4"><span class="small fw-semibold">Chicharrones</span></div>
                        <div class="col-4">
                            <input asp-for="CracklingsSold" type="number" step="1" min="0"
                                   class="form-control form-control-sm calc-input" />
                        </div>
                        <div class="col-4"></div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Columna derecha: resumen y cierre -->
        <div class="col-lg-4">

            <!-- Diferencia Carga − Tabla -->
            <div class="card mb-4">
                <div class="card-header" style="background:#faf5ff;color:#7e22ce;">
                    <i class="bi bi-calculator me-2"></i>Diferencia Carga − Tabla
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2 pb-1" style="border-bottom:1px solid #f3f4f6;">
                        <span class="small text-muted">Kilos</span>
                        <span class="fw-bold" id="difKilos">—</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 pb-1" style="border-bottom:1px solid #f3f4f6;">
                        <span class="small text-muted">Paquetes</span>
                        <span class="fw-bold" id="difPaquetes">—</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 pb-1" style="border-bottom:1px solid #f3f4f6;">
                        <span class="small text-muted">Totopos</span>
                        <span class="fw-bold" id="difTotopos">—</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 pb-1" style="border-bottom:1px solid #f3f4f6;">
                        <span class="small text-muted">Masa</span>
                        <span class="fw-bold" id="difMasa">—</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="small text-muted">Chicharrones</span>
                        <span class="fw-bold" id="difChicha">—</span>
                    </div>
                </div>
            </div>

            <!-- Faltantes del día -->
            <div class="card mb-4">
                <div class="card-header" style="background:#fef2f2;color:#991b1b;">
                    <i class="bi bi-exclamation-triangle me-2"></i>Faltantes del día
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small fw-semibold">Kilos</span>
                        <span class="fw-bold fs-5" id="dispFaltKilos">—</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small fw-semibold">Paquetes</span>
                        <span class="fw-bold fs-5" id="dispFaltPqts">—</span>
                    </div>
                    <input type="hidden" asp-for="ShortageKilos" />
                    <input type="hidden" asp-for="ShortagePackages" />
                </div>
            </div>

            <!-- Cierre y firma -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-person-check me-2 text-primary"></i>Cierre y firma
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Vendedor</label>
                        <select asp-for="SalespersonId" asp-items="ViewBag.Vendedores"
                                class="form-select form-select-sm">
                            <option value="">— Sin asignar —</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="SalespersonSigned" class="form-check-input" type="checkbox" />
                            <label class="form-check-label small fw-semibold" asp-for="SalespersonSigned">
                                Vendedor firmó cuadranza
                            </label>
                        </div>
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-semibold small">Notas / Observaciones</label>
                        <textarea asp-for="Notes" class="form-control form-control-sm" rows="3"
                                  placeholder="Observaciones del día..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-check-lg me-1"></i>Guardar
                </button>
                <a href="/Cuadranza?fecha=@fecha.ToString("yyyy-MM-dd")"
                   class="btn btn-outline-secondary">Cancelar</a>
            </div>

        </div>
    </div>
</form>

@section Scripts {
<script>
(function () {
    function g(id) { return parseFloat(document.getElementById(id)?.value) || 0; }
    function fmt(n) { return n.toFixed(2); }

    function colorear(el, val) {
        el.style.color = val > 0 ? '#dc2626' : val < 0 ? '#7c3aed' : '#059669';
    }

    function recalcular() {
        var cargaCaliente = g('LoadHotKilos') + g('LoadHalfKilo') + g('LoadTacoKilo');
        var cargaFrio = g('LoadPackages') + g('LoadHalfPackage') + g('LoadTacoPackage');

        // Totales de carga
        document.getElementById('totalCaliente').textContent = fmt(cargaCaliente) + ' kg';
        document.getElementById('totalFrio').textContent = fmt(cargaFrio) + ' pqts';

        // Diferencia Carga - Tabla
        var diffs = [
            ['difKilos', cargaCaliente - g('TableHotKilos')],
            ['difPaquetes', cargaFrio - g('TablePackages')],
            ['difTotopos', g('LoadChips') - g('TableChips')],
            ['difMasa', g('LoadDough') - g('TableDough')],
            ['difChicha', g('LoadCrackling') - g('TableCrackling')]
        ];

        diffs.forEach(function (d) {
            var el = document.getElementById(d[0]);
            el.textContent = fmt(d[1]);
            colorear(el, d[1]);
        });

        // Faltantes
        var faltKilos = cargaCaliente - g('KilosSold') - g('KilosReturned');
        var faltPqts = cargaFrio - g('PackagesSold') - g('PackagesReturned');

        var elFK = document.getElementById('dispFaltKilos');
        var elFP = document.getElementById('dispFaltPqts');

        elFK.textContent = fmt(faltKilos);
        elFP.textContent = fmt(faltPqts);
        colorear(elFK, faltKilos);
        colorear(elFP, faltPqts);

        // Actualizar hidden inputs (el servidor también los calcula, esto es por si acaso)
        document.getElementById('ShortageKilos').value = fmt(faltKilos);
        document.getElementById('ShortagePackages').value = fmt(faltPqts);
    }

    document.querySelectorAll('.calc-input').forEach(function (el) {
        el.addEventListener('input', recalcular);
    });

    recalcular();
})();
</script>
}
