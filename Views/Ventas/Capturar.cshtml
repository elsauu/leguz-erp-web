@model LEGUZ.Models.Entities.DailySalesRecord
@{
    var ruta = (LEGUZ.Models.Entities.DeliveryRoute)ViewBag.Ruta;
    var fecha = (DateOnly)ViewBag.Fecha;
    bool isEdit = Model.DailySalesRecordId > 0;
    string actionUrl = isEdit ? $"/Ventas/Editar/{Model.DailySalesRecordId}" : "/Ventas/Capturar";

    var cultura = new System.Globalization.CultureInfo("es-MX");
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card mb-3">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div>
                    <div style="font-size:.75rem;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Ruta</div>
                    <div class="fw-semibold" style="font-size:1.1rem;">
                        @ruta.Number.ToString("D2") — @ruta.Name
                    </div>
                </div>
                <div>
                    <div style="font-size:.75rem;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Fecha</div>
                    <div class="fw-semibold">@fecha.ToString("dddd dd 'de' MMMM yyyy", cultura)</div>
                </div>
                <a href="/Ventas?fecha=@fecha.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Volver
                </a>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-cash-stack me-2 text-primary"></i>
                @(isEdit ? "Editar liquidación" : "Capturar liquidación")
            </div>
            <div class="card-body">
                <form method="post" action="@actionUrl">
                    @Html.AntiForgeryToken()
                    <input asp-for="DailySalesRecordId" type="hidden" />
                    <input asp-for="DeliveryRouteId" type="hidden" />
                    <input asp-for="Date" type="hidden" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Vendedor</label>
                            <select asp-for="SalespersonId" class="form-select" asp-items="ViewBag.Vendedores">
                                <option value="">— Sin asignar —</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Venta total ($) <span class="text-danger">*</span></label>
                            <input asp-for="TotalSale" class="form-control" type="number" min="0" step="0.01"
                                   id="totalSale" />
                            <span asp-validation-for="TotalSale" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h6 class="fw-semibold mb-3 text-secondary">Desglose del efectivo recibido</h6>

                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Billetes ($)</label>
                            <input asp-for="Bills" class="form-control liquidacion-input" type="number" min="0" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Monedas ($)</label>
                            <input asp-for="Coins" class="form-control liquidacion-input" type="number" min="0" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Cheques ($)</label>
                            <input asp-for="CheckPayment" class="form-control liquidacion-input" type="number" min="0" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Gastos ($)</label>
                            <input asp-for="Expenses" class="form-control liquidacion-input" type="number" min="0" step="0.01" />
                        </div>
                    </div>

                    <!-- Cálculo en vivo -->
                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <div class="p-3" style="background:#f9fafb;border-radius:8px;">
                                <div style="font-size:.75rem;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Total entregado</div>
                                <div class="fw-bold" style="font-size:1.3rem;color:#111827;">
                                    $<span id="totalEntregado">0.00</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3" id="faltanteBox" style="background:#f0fdf4;border-radius:8px;">
                                <div style="font-size:.75rem;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;">Faltante calculado</div>
                                <div class="fw-bold" style="font-size:1.3rem;" id="faltanteValor">$0.00</div>
                                <div style="font-size:.7rem;color:#9ca3af;">Se guarda automáticamente al enviar</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label fw-semibold">Notas</label>
                        <textarea asp-for="Notes" class="form-control" rows="2" maxlength="500"
                                  placeholder="Observaciones de la liquidación"></textarea>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>@(isEdit ? "Guardar cambios" : "Guardar liquidación")
                        </button>
                        <a href="/Ventas?fecha=@fecha.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function recalcular() {
            const get = id => parseFloat(document.getElementById(id)?.value || 0) || 0;
            const total = get('totalSale');
            const bills = get('@Html.IdFor(m => m.Bills)');
            const coins = get('@Html.IdFor(m => m.Coins)');
            const cheques = get('@Html.IdFor(m => m.CheckPayment)');
            const gastos = get('@Html.IdFor(m => m.Expenses)');

            const entregado = bills + coins + cheques + gastos;
            const faltante = total - entregado;

            document.getElementById('totalEntregado').textContent = entregado.toFixed(2);
            const faltanteEl = document.getElementById('faltanteValor');
            const box = document.getElementById('faltanteBox');
            faltanteEl.textContent = '$' + faltante.toFixed(2);

            if (faltante > 0.001) {
                box.style.background = '#fef2f2';
                faltanteEl.style.color = '#b91c1c';
            } else if (faltante < -0.001) {
                box.style.background = '#eff6ff';
                faltanteEl.style.color = '#1d4ed8';
            } else {
                box.style.background = '#f0fdf4';
                faltanteEl.style.color = '#059669';
            }
        }

        document.querySelectorAll('#totalSale, .liquidacion-input').forEach(el => {
            el.addEventListener('input', recalcular);
        });
        recalcular();
    </script>
}
