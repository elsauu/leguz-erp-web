@{
    ViewData["Title"] = "Dashboard";
}

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card" style="background: linear-gradient(135deg,#2563eb,#1d4ed8)">
            <i class="bi bi-map kpi-icon"></i>
            <div class="kpi-value">@ViewBag.ActiveRoutes</div>
            <div class="kpi-label">Rutas activas</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card" style="background: linear-gradient(135deg,#059669,#047857)">
            <i class="bi bi-people kpi-icon"></i>
            <div class="kpi-value">@ViewBag.ActiveSalespersons</div>
            <div class="kpi-label">Vendedores activos</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card" style="background: linear-gradient(135deg,#d97706,#b45309)">
            <i class="bi bi-receipt kpi-icon"></i>
            <div class="kpi-value">@ViewBag.PendingCreditNotes</div>
            <div class="kpi-label">Notas de crédito pendientes</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card" style="background: linear-gradient(135deg,#7c3aed,#6d28d9)">
            <i class="bi bi-cash-stack kpi-icon"></i>
            <div class="kpi-value">$@string.Format("{0:N0}", ViewBag.TodaySalesTotal)</div>
            <div class="kpi-label">Ventas de hoy</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Chart -->
    <div class="col-xl-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-bar-chart-line me-2 text-primary"></i>Ventas por ruta — semana actual</span>
            </div>
            <div class="card-body">
                <canvas id="salesChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent credit notes -->
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-receipt me-2 text-warning"></i>Últimas notas de crédito</span>
                <a href="/CreditNote" class="btn btn-sm btn-outline-primary">Ver todas</a>
            </div>
            <div class="card-body p-0">
                @if (ViewBag.RecentCreditNotes != null && ((IEnumerable<dynamic>)ViewBag.RecentCreditNotes).Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var note in ViewBag.RecentCreditNotes)
                        {
                            <li class="list-group-item px-3 py-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div style="font-size:.85rem;font-weight:600;">@note.StoreName</div>
                                        <div style="font-size:.75rem;color:#6b7280;">
                                            @note.DeliveryRoute?.Name — @note.Date.ToString("dd/MM/yyyy")
                                        </div>
                                    </div>
                                    <span class="badge badge-pending rounded-pill">@note.Status</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center py-4" style="color:#9ca3af;font-size:.85rem;">
                        <i class="bi bi-inbox" style="font-size:2rem;"></i>
                        <div class="mt-2">Sin notas recientes</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Quick access -->
<div class="row g-3 mt-1">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-lightning-charge me-2 text-warning"></i>Acceso rápido
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a href="/DailyRoute" class="btn btn-outline-primary">
                        <i class="bi bi-clipboard-data me-2"></i>Nueva cuadranza
                    </a>
                    <a href="/CreditNote/Create" class="btn btn-outline-warning">
                        <i class="bi bi-receipt me-2"></i>Nueva nota de crédito
                    </a>
                    <a href="/Sales" class="btn btn-outline-success">
                        <i class="bi bi-cash-stack me-2"></i>Registrar ventas
                    </a>
                    <a href="/Deposit" class="btn btn-outline-info">
                        <i class="bi bi-bank me-2"></i>Registrar depósito
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.WeeklyLabels ?? new List<string>()));
        const data   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.WeeklyTotals ?? new List<decimal>()));

        new Chart(document.getElementById('salesChart'), {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: 'Ventas ($)',
                    data,
                    backgroundColor: 'rgba(37,99,235,0.15)',
                    borderColor: '#2563eb',
                    borderWidth: 2,
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: v => '$' + v.toLocaleString('es-MX')
                        }
                    }
                }
            }
        });
    </script>
}