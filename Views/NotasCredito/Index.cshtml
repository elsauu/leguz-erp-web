@model IEnumerable<LEGUZ.Models.Entities.CreditNote>
@{
    ViewData["Title"] = "Notas de Crédito";
    var currentStatus = ViewData["CurrentStatus"]?.ToString() ?? "ALL";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-3" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="bi bi-receipt me-2 text-primary"></i>Notas de crédito</span>
        <div class="d-flex gap-2 align-items-center">
            <div class="btn-group btn-group-sm" role="group">
                <a href="/NotasCredito?status=ALL"
                   class="btn @(currentStatus == "ALL" ? "btn-primary" : "btn-outline-secondary")">Todas</a>
                <a href="/NotasCredito?status=PENDING"
                   class="btn @(currentStatus == "PENDING" ? "btn-primary" : "btn-outline-secondary")">Pendientes</a>
                <a href="/NotasCredito?status=SETTLED"
                   class="btn @(currentStatus == "SETTLED" ? "btn-primary" : "btn-outline-secondary")">Liquidadas</a>
                <a href="/NotasCredito?status=CANCELLED"
                   class="btn @(currentStatus == "CANCELLED" ? "btn-primary" : "btn-outline-secondary")">Canceladas</a>
            </div>
            <a href="/NotasCredito/Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Nueva nota
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Folio</th>
                        <th>Fecha</th>
                        <th>Tienda / Cliente</th>
                        <th>Ruta</th>
                        <th>Vendedor</th>
                        <th class="text-end">Paquetes</th>
                        <th class="text-end">Kilos</th>
                        <th>Estatus</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in Model)
                    {
                        <tr>
                            <td><span class="fw-bold text-primary">@n.FolioNumber</span></td>
                            <td>@n.Date.ToString("dd/MM/yyyy")</td>
                            <td class="fw-semibold">
                                @(n.StoreName ?? n.Customer?.Name ?? "—")
                                @if (n.IsBarbacoa)
                                {
                                    <span class="badge ms-1" style="background:#fee2e2;color:#991b1b;">Barbacoa</span>
                                }
                            </td>
                            <td>@(n.DeliveryRoute?.Name ?? "—")</td>
                            <td>@(n.Salesperson != null ? $"{n.Salesperson.FirstName} {n.Salesperson.LastName}" : "—")</td>
                            <td class="text-end">@n.Packages.ToString("F2")</td>
                            <td class="text-end">@n.Kilos.ToString("F2")</td>
                            <td>
                                @{
                                    var (badgeClass, label) = n.Status switch
                                    {
                                        "PENDING"   => ("badge-pending", "Pendiente"),
                                        "SETTLED"   => ("badge-settled", "Liquidada"),
                                        "CANCELLED" => ("badge-cancelled", "Cancelada"),
                                        _           => ("badge-pending", n.Status)
                                    };
                                }
                                <span class="badge @badgeClass rounded-pill">@label</span>
                            </td>
                            <td class="text-end">
                                <a href="/NotasCredito/Edit/@n.CreditNoteId"
                                   class="btn btn-sm btn-outline-secondary me-1" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (n.Status == "PENDING")
                                {
                                    <form method="post" action="/NotasCredito/ChangeStatus" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@n.CreditNoteId" />
                                        <input type="hidden" name="status" value="SETTLED" />
                                        <button type="submit" class="btn btn-sm btn-outline-success me-1" title="Marcar liquidada">
                                            <i class="bi bi-check2-circle"></i>
                                        </button>
                                    </form>
                                    <form method="post" action="/NotasCredito/ChangeStatus" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@n.CreditNoteId" />
                                        <input type="hidden" name="status" value="CANCELLED" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Cancelar">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" action="/NotasCredito/ChangeStatus" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@n.CreditNoteId" />
                                        <input type="hidden" name="status" value="PENDING" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Reabrir como pendiente">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4" style="color:#9ca3af;">
                                No hay notas de crédito registradas con este filtro.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
