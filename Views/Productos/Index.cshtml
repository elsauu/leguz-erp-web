@model IEnumerable<LEGUZ.Models.Entities.Product>
@{
    ViewData["Title"] = "Productos";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-3" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-box-seam me-2 text-primary"></i>Catálogo de productos</span>
        <a href="/Productos/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo producto
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Unidad</th>
                    <th class="text-end">Precio unitario</th>
                    <th>Estatus</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><span class="fw-bold text-primary">@p.Code</span></td>
                        <td class="fw-semibold">@p.Name</td>
                        <td>
                            @{
                                var (bg, fg, label) = p.Category switch
                                {
                                    "HOT"          => ("#fef9c3", "#854d0e", "Caliente"),
                                    "COLD"         => ("#dbeafe", "#1e40af", "Frío"),
                                    "CHIPS"        => ("#ffedd5", "#9a3412", "Totopos"),
                                    "DOUGH"        => ("#dcfce7", "#166534", "Masa"),
                                    "CRACKLING"    => ("#f3e8ff", "#6b21a8", "Chicharrón"),
                                    "PRESENTATION" => ("#e0f2fe", "#0369a1", "Presentación"),
                                    _              => ("#f3f4f6", "#374151", p.Category)
                                };
                            }
                            <span class="badge" style="background:@bg;color:@fg;">@label</span>
                        </td>
                        <td>
                            @(p.Unit switch { "KG" => "Kilogramo", "PACKAGE" => "Paquete", "PIECE" => "Pieza", _ => p.Unit })
                        </td>
                        <td class="text-end">$@p.UnitPrice.ToString("F2")</td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge badge-settled rounded-pill">Activo</span>
                            }
                            else
                            {
                                <span class="badge badge-cancelled rounded-pill">Inactivo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a href="/Productos/Edit/@p.ProductId"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="/Productos/Toggle/@p.ProductId"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(p.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                        title="@(p.IsActive ? "Desactivar" : "Activar")">
                                    <i class="bi @(p.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4" style="color:#9ca3af;">
                            No hay productos registrados aún.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
