@model LEGUZ.Models.Entities.Product
@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-box-seam me-2 text-primary"></i>Nuevo producto
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Código <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control" placeholder="Ej. KG-CAL" maxlength="20" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Ej. KILO CALIENTE" maxlength="60" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Categoría <span class="text-danger">*</span></label>
                        <select asp-for="Category" class="form-select">
                            <option value="HOT">Caliente (tortilla caliente)</option>
                            <option value="COLD">Frío (tortilla fría)</option>
                            <option value="CHIPS">Totopos</option>
                            <option value="DOUGH">Masa</option>
                            <option value="CRACKLING">Chicharrón</option>
                            <option value="PRESENTATION">Presentación</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Unidad <span class="text-danger">*</span></label>
                        <select asp-for="Unit" class="form-select">
                            <option value="KG">Kilogramo</option>
                            <option value="PACKAGE">Paquete</option>
                            <option value="PIECE">Pieza</option>
                        </select>
                        <span asp-validation-for="Unit" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Precio unitario ($)</label>
                        <input asp-for="UnitPrice" class="form-control" type="number" min="0" step="0.01" placeholder="0.00" />
                        <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar
                        </button>
                        <a href="/Productos" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
