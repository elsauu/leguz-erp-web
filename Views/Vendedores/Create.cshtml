@model LEGUZ.Models.Entities.Salesperson
@{
    ViewData["Title"] = "Nuevo Vendedor";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-person-plus me-2 text-primary"></i>Nuevo vendedor
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre(s) <span class="text-danger">*</span></label>
                        <input asp-for="FirstName" class="form-control" placeholder="Ej. Juan Carlos" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Apellidos</label>
                        <input asp-for="LastName" class="form-control" placeholder="Ej. García López" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tipo <span class="text-danger">*</span></label>
                        <select asp-for="Type" id="typeSelect" class="form-select">
                            <option value="ROUTE">Ruta</option>
                            <option value="MOTORCYCLE">Moto</option>
                            <option value="STORE">Mostrador</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>

                    <div class="mb-3" id="routeGroup">
                        <label class="form-label fw-semibold">Ruta asignada</label>
                        <select asp-for="DeliveryRouteId" asp-items="ViewBag.Routes" class="form-select">
                            <option value="">— Sin asignar —</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Teléfono</label>
                        <input asp-for="Phone" class="form-control" placeholder="Ej. 8991234567" maxlength="15" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar
                        </button>
                        <a href="/Vendedores" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const typeSelect = document.getElementById('typeSelect');
    const routeGroup = document.getElementById('routeGroup');

    function toggleRoute() {
        routeGroup.style.display = typeSelect.value === 'ROUTE' ? '' : 'none';
    }

    typeSelect.addEventListener('change', toggleRoute);
    toggleRoute();
</script>
}
