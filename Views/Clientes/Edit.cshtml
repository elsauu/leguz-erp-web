@model LEGUZ.Models.Entities.Customer
@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-pencil me-2 text-primary"></i>Editar cliente
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="CustomerId" type="hidden" />
                    <input asp-for="CreatedAt" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Canal <span class="text-danger">*</span></label>
                        <select asp-for="CustomerType" id="typeSelect" class="form-select">
                            <option value="ROUTE">Ruta</option>
                            <option value="SUPERMARKET">Autoservicio</option>
                            <option value="MOTORCYCLE">Moto</option>
                            <option value="STORE">Mostrador</option>
                        </select>
                        <span asp-validation-for="CustomerType" class="text-danger small"></span>
                    </div>

                    <div class="mb-3" id="routeGroup">
                        <label class="form-label fw-semibold">Ruta asignada</label>
                        <select asp-for="DeliveryRouteId" asp-items="ViewBag.Routes" class="form-select">
                            <option value="">— Sin asignar —</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Teléfono</label>
                        <input asp-for="Phone" class="form-control" maxlength="15" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Dirección</label>
                        <input asp-for="Address" class="form-control" maxlength="200" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label">Cliente activo</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar cambios
                        </button>
                        <a href="/Clientes" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const typeSelect = document.getElementById('typeSelect');
    const routeGroup = document.getElementById('routeGroup');

    function toggleRoute() {
        routeGroup.style.display = typeSelect.value === 'ROUTE' ? '' : 'none';
    }

    typeSelect.addEventListener('change', toggleRoute);
    toggleRoute();
</script>
}
